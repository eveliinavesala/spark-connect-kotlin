root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.kt]
# Disabled: conflicts with detekt MaxLineLength — a long expression body would exceed 120 chars,
# requiring a block body, which this rule then flags as needing to revert to expression body.
ktlint_standard_function-expression-body = disabled
